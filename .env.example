# Copy this file to `.env` (or run: cp .env.example .env) and adjust if needed.
#
# These values control the UID/GID used inside the container so that files
# created in the bind-mounted `localhost/www/html` directory are owned by
# your host user instead of root.
#
# On Linux/macOS, you can populate them with your current user's IDs:
#   echo "PUID=$(id -u)" >  .env
#   echo "PGID=$(id -g)" >> .env

PUID=1000
PGID=1000
